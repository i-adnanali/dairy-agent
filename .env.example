ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
PORT=4000

# Langfuse (self-hosted) observability.
# Start the stack with: docker compose -f docker-compose.langfuse.yml up -d
# Then open http://localhost:3000, create a project, and paste its keys here.
# If these are unset, tracing is silently disabled and the agent runs normally.
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_BASE_URL=http://localhost:3000
